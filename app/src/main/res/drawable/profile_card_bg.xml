<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Card color -->
    <solid android:color="@android:color/white" />

    <!-- Rounded corners -->
    <corners android:radius="25dp" />

    <!-- Soft inner padding (optional) -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />

    <!-- Optional stroke (for subtle border effect) -->
    <stroke
        android:width="0.5dp"
        android:color="#E5E5E5" />
</shape>
