<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checkout Summary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0D2A4D"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_checkout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tv_total_amounts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Amount: ₹ 0"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#007F00"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tv_order_messages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="#444444"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btn_place_orders"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Place Order"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:backgroundTint="#0D2A4D"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp" />

</LinearLayout>