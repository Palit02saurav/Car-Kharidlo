<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F6FA"
    tools:context=".ui.listings.NewListing">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- PAGE TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Listing"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0D2A4D"
            android:layout_marginBottom="20dp" />

        <!-- UPLOAD IMAGE -->
        <ImageView
            android:id="@+id/img_car_preview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="@drawable/button_ternary"
            android:src="@drawable/placeholder_image"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_upload_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Car Image"
            android:backgroundTint="#0D2A4D"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp" />

        <!-- CAR NAME -->
        <EditText
            android:id="@+id/et_car_name"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Car Name"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- PRICE -->
        <EditText
            android:id="@+id/et_car_price"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Price (₹)"
            android:inputType="number"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- EMAIL -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Your Email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- CONTACT -->
        <EditText
            android:id="@+id/et_contact"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Contact Number"
            android:inputType="phone"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- ADDRESS -->
        <EditText
            android:id="@+id/et_address"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Address"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- STATE -->
        <EditText
            android:id="@+id/et_state"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="State"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- CITY -->
        <EditText
            android:id="@+id/et_city"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="City"
            android:padding="12dp"
            android:background="@drawable/rounded"
            android:textSize="16sp"
            android:layout_marginBottom="20dp" />

        <!-- SUBMIT BUTTON -->
        <Button
            android:id="@+id/btn_submit_listing"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Submit Listing"
            android:layout_marginLeft="80dp"
            android:layout_marginRight="80dp"
            android:textSize="18sp"

            android:background="@drawable/button_ternary"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F47B20"
            android:layout_marginBottom="40dp" />

    </LinearLayout>

</ScrollView>
