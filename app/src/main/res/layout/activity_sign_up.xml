<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/signin"
    tools:context=".ui.Sign_Up_Activity">

    <TextView
        android:id="@+id/signin_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sign_up"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="36sp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="35dp"/>
    <TextView
        android:id="@+id/para_signin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/just_a_few_quick_things_to_get_started_2"
        android:textColor="@color/black"
        android:textSize="17sp"
        android:layout_marginStart="20dp"
        android:layout_below="@+id/signin_text"
        android:layout_marginTop="5dp"/>

    <TextView
        android:id="@+id/signin_emailid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/para_signin"
        android:text="@string/email_id"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="28dp"
        android:layout_marginStart="20dp"
        android:textSize="23sp"/>

    <EditText
        android:id="@+id/signin_email_box"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:autofillHints="TODO"
        android:hint="@string/enter_email_id"
        android:textSize="18sp"
        android:background="@drawable/rounded"
        android:paddingStart="25dp"
        android:layout_below="@+id/signin_emailid"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="30dp"
        tools:ignore="RtlSymmetry,TextFields" />





    <TextView
        android:id="@+id/signin_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/signin_email_box"
        android:text="@string/new_password"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:textSize="23sp"/>

    <EditText
        android:id="@+id/signin_password_box"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:autofillHints="TODO"
        android:paddingStart="25dp"
        android:textSize="18sp"
        android:hint="@string/enter_password"
        android:background="@drawable/rounded"
        android:layout_below="@+id/signin_password"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="30dp"
        tools:ignore="RtlSymmetry,TextFields" />






    <TextView
        android:id="@+id/confirm_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/signin_password_box"
        android:text="@string/confirm_password"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:textSize="23sp"/>

    <EditText
        android:id="@+id/confirm_password_box"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:paddingStart="25dp"
        android:hint="@string/enter_password39"
        android:textSize="18sp"
        android:background="@drawable/rounded"
        android:layout_below="@+id/confirm_password"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="30dp"
        tools:ignore="Autofill,RtlSymmetry,TextFields" />






    <CheckBox
        android:id="@+id/signup_checkbox"
        android:layout_width="23dp"
        android:layout_height="23dp"
        android:layout_below="@+id/confirm_password_box"
        android:layout_marginStart="21dp"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/signin_remember_me"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/i_agree_with_the_term_s_and_condition_s"
        android:layout_marginTop="12dp"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_toEndOf="@+id/signup_checkbox"
        android:paddingStart="5dp"
        android:layout_below="@+id/confirm_password_box"
        tools:ignore="RtlSymmetry" />



    <Button
        android:id="@+id/sign_in_button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_below="@+id/signup_checkbox"
        android:layout_marginLeft="50dp"
        android:layout_marginRight="50dp"
        android:layout_marginTop="20dp"
        android:text="@string/sign_up38"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:background="@drawable/signup_button"/>


    <LinearLayout
        android:id="@+id/divider_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_below="@+id/sign_in_button"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="30dp"
        android:layout_marginRight="30dp">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#615C5C" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or_with"
            android:textColor="#070707"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#837D7D" />
    </LinearLayout>


    <Button
        android:id="@+id/facebook_button"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="15dp"
        android:layout_below="@+id/divider_section"
        android:background="@drawable/button_ternary"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:layout_marginEnd="230dp"
        android:text="@string/facebook"
        android:layout_marginStart="30dp"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:drawableStart="@drawable/ic_facebook"
        android:drawablePadding="10dp"
        android:gravity="center_vertical|center_horizontal"
        />


    <Button
        android:id="@+id/google_button"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="15dp"
        android:layout_below="@+id/divider_section"
        android:background="@drawable/button_ternary"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:layout_marginStart="230dp"
        android:text="@string/google"
        android:layout_marginEnd="30dp"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:drawableStart="@drawable/ic_google"
        android:drawablePadding="10dp"
        android:gravity="center_vertical|center_horizontal"
        />


    <TextView
        android:id="@+id/bottom_text_01"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/already_have_an_account"
        android:textColor="#575353"
        android:textSize="15sp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="10dp" />


    <TextView
        android:id="@+id/bottom_text_02"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/signin"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_toEndOf="@+id/bottom_text_01"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />
</RelativeLayout>