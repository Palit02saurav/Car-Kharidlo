<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050816"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sell Your Car"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/carImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@drawable/bg_premium_input"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true" />

        <EditText
            android:id="@+id/etCarName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:hint="Car Name"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:background="@drawable/bg_premium_input"
            android:padding="15dp" />

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Price"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:background="@drawable/bg_premium_input"
            android:padding="15dp"
            android:inputType="number" />

        <EditText
            android:id="@+id/etDriven"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Driven KM"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:background="@drawable/bg_premium_input"
            android:padding="15dp"
            android:inputType="number" />

        <EditText
            android:id="@+id/etFuel"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Fuel Type"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:background="@drawable/bg_premium_input"
            android:padding="15dp" />

        <EditText
            android:id="@+id/etTransmission"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:hint="Transmission"
            android:textColor="#000000"
            android:textColorHint="#666666"
            android:background="@drawable/bg_premium_input"
            android:padding="15dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/bg_premium_input" />

        <Button
            android:id="@+id/btnListCar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="25dp"
            android:text="List My Car"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_premium_button" />

    </LinearLayout>
</ScrollView>